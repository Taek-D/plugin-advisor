# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# GitHub API (optional, for higher rate limits on version checks)
GITHUB_TOKEN=<github-personal-access-token>

# Anthropic API (optional, enables AI-powered analysis)
ANTHROPIC_API_KEY=<anthropic-api-key>

# Umami Analytics (optional, enables page view and event tracking)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=<umami-website-id>
NEXT_PUBLIC_UMAMI_PROXY_URL=/api/umami

# Lead capture (optional, forwards setup requests to your webhook)
LEAD_WEBHOOK_URL=https://example.com/webhook

# Admin review
ADMIN_REVIEW_PASSWORD=<admin-review-password>
ADMIN_SESSION_SECRET=<long-random-session-secret>
